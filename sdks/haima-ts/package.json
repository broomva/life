{
  "name": "life-haima",
  "version": "0.1.0",
  "description": "Multi-framework x402 payment SDK for AI agents — TypeScript bindings for Life Agent OS Haima subsystem",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./elizaos": {
      "types": "./dist/integrations/elizaos.d.ts",
      "import": "./dist/integrations/elizaos.js"
    },
    "./openai": {
      "types": "./dist/integrations/openai.d.ts",
      "import": "./dist/integrations/openai.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["x402", "payments", "ai-agent", "haima", "life-agent-os", "web3"],
  "author": "Broomva <carlos@broomva.tech>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/broomva/life"
  },
  "homepage": "https://broomva.tech",
  "dependencies": {
    "viem": "^2.21"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7",
    "vitest": "^3.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.2",
    "openai": ">=4.70"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  }
}
