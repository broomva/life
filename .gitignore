# ═══════════════════════════════════════════════════════════════════
# Life Agent OS — .gitignore
# ═══════════════════════════════════════════════════════════════════

# Rust build artifacts
/target/
/.target/
**/target/

# Environment files (secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Agent runtime data
.arcan/
.lago/
.aios/
.aios-*/

# Claude Code worktrees
.claude/worktrees/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# TypeScript / Node.js
node_modules/
*.tsbuildinfo
**/dist/
**/.next/

# Vercel
.vercel/

# Lake / Lean
.lake/

# Test artifacts
test.txt

# Local symlinks (absolute paths, not portable)
crates/anima/anima-data

# Internal session logs and raw data (not for public)
docs/conversations/
raw-dumps/
