# ═══════════════════════════════════════════════════════════════════
# Life Agent OS — .gitignore
# ═══════════════════════════════════════════════════════════════════

# Rust build artifacts
/target/
/.target/
**/target/

# Environment files (secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Agent runtime data
.arcan/
.lago/
.aios/
.aios-*/

# Life unified filesystem (runtime state is gitignored, control/ is committed)
.life/*
!.life/config.toml
!.life/control/

# Claude Code worktrees
.claude/worktrees/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# TypeScript / Node.js
node_modules/
*.tsbuildinfo
**/dist/
**/.next/

# Vercel
.vercel/

# Lake / Lean
.lake/

# Test artifacts
test.txt

# Local symlinks (absolute paths, not portable)
crates/anima/anima-data

# Internal session logs and raw data (not for public)
docs/conversations/
raw-dumps/
interface/docs/conversations/
docs/raw-dumps/
.entire/

# Arcan session data and worktrees (machine-specific)
arcan/.arcan/
crates/arcan/.claude/worktrees/
crates/anima/anima-data

# Conversation bridge (local only, generates docs/conversations/)
scripts/conversation-history.py
scripts/conversation-bridge-hook.sh

# Opsis frontend (crates/opsis/web/)
crates/opsis/web/.turbo/
crates/opsis/web/docs/conversations/
crates/opsis/web/scripts/conversation-history.py
crates/opsis/web/scripts/conversation-bridge-hook.sh
