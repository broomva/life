#!/bin/sh
# Validate conventional commit format
# Allow merge commits and Co-Authored-By lines
first_line=$(head -1 "$1")
if echo "$first_line" | grep -qE '^Merge '; then
  exit 0
fi
echo "$first_line" | grep -qE '^(feat|fix|chore|docs|refactor|test|ci|perf)(\(.+\))?: .+' || {
  echo "Error: commit message must follow conventional commits format"
  echo "  <type>(<scope>): <subject>"
  echo "  Example: feat(arcan): add streaming markdown renderer"
  exit 1
}
