{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": ["NEXT_PUBLIC_CESIUM_ION_TOKEN", "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY", "OPSIS_URL"]
    },
    "lint": {},
    "check-types": {}
  }
}
