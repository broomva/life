# Lago Event-Sourced Persistence — Environment Variables
# Copy to .env and fill in your values. Never commit .env files.
#
#   cp env.example .env

# ─── Lago Daemon ─────────────────────────────────────────────────
# LAGO_GRPC_PORT=50051
# LAGO_HTTP_PORT=8080
# LAGO_DATA_DIR=.lago
# LAGO_CONFIG=lago.toml

# ─── Auth (Memory API) ──────────────────────────────────────────
# Shared JWT secret (same as broomva.tech AUTH_SECRET)
# When set, /v1/memory/* routes require a valid JWT bearer token
# LAGO_JWT_SECRET=

# ─── Logging ─────────────────────────────────────────────────────
# RUST_LOG=info
# RUST_LOG=lago_api=debug,lago_journal=debug
