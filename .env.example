# Life Agent OS — Local Development Environment
# Copy to .env and fill in values:  cp .env.example .env
# Source before running services:   source .env && cargo run -p arcan ...

# LLM Provider (Vercel AI Gateway)
OPENAI_BASE_URL=https://ai-gateway.vercel.sh
OPENAI_API_KEY=

# Opsis World State Bridge
OPSIS_URL=http://localhost:3010

# Vigil OTEL -> LangSmith
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel/v1/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=x-api-key=
OTEL_SERVICE_NAME=arcan
VIGIL_CAPTURE_CONTENT=true

# Service Ports
ARCAN_PORT=3000
OPSISD_PORT=3010
