# Life Agent OS — Environment Variables
# Copy to .env and fill in your values. Never commit .env files.
#
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════════════
# Arcan — Agent Runtime
# ═══════════════════════════════════════════════════════════════════

# Provider: "anthropic", "openai", "ollama", "apfel" (Apple on-device)
# Auto-detects from available API keys if unset.
# ARCAN_PROVIDER=anthropic

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI / OpenAI-compatible (GPT-4o, Together, Groq, vLLM)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com

# Ollama (local models — no API key needed)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Server
# ARCAN_PORT=3000
# ARCAN_DATA_DIR=.arcan
# ARCAN_JWT_SECRET=           # Shared HMAC secret for JWT auth (same as AUTH_SECRET)
# ARCAN_AUTONOMIC_URL=http://localhost:3002

# ═══════════════════════════════════════════════════════════════════
# Lago — Event-Sourced Persistence
# ═══════════════════════════════════════════════════════════════════

# LAGO_HTTP_PORT=8080
# LAGO_GRPC_PORT=50051
# LAGO_DATA_DIR=.lago
# LAGO_JWT_SECRET=            # Shared JWT secret for memory API auth

# ═══════════════════════════════════════════════════════════════════
# Autonomic — Homeostasis Controller
# ═══════════════════════════════════════════════════════════════════

# AUTONOMIC_PORT=3002
# AUTONOMIC_JWT_SECRET=

# ═══════════════════════════════════════════════════════════════════
# Haima — Agentic Finance Engine
# ═══════════════════════════════════════════════════════════════════

# HAIMA_PORT=3003
# HAIMA_JWT_SECRET=

# ═══════════════════════════════════════════════════════════════════
# Observability (OpenTelemetry — shared across all services)
# ═══════════════════════════════════════════════════════════════════

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=arcan
# RUST_LOG=info
